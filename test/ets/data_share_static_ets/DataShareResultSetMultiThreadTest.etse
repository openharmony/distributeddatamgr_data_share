async function getBlobTest(context: common.UIAbilityContext, value: Array<int>): Promise<Array<int>> {
  const TAG = "[ttt-getBlobTest] "
  value = new Array<int>();
  let dataShareHelper: dataShare.DataShareHelper | undefined = undefined
