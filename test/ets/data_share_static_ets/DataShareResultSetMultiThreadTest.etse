async function getLongTest(context: common.UIAbilityContext, value: Array<int>): Promise<Array<int>> {
  const TAG = "[ttt-getLongTest] "
  value = new Array<int>();
  let dataShareHelper: dataShare.DataShareHelper | undefined = undefined
  let uri = ("datashareproxy://com.acts.ohos.data.datasharetest.static/test");
  let ReturnCode = 0;
  let columns = ["*"];
  let da = new dataSharePredicates.DataSharePredicates();
  let resultSet: DataShareResultSet | undefined;
  try {
    dataShareHelper = await dataShare.createDataShareHelper(context, uri, { isProxy: true });
    console.log(TAG + "dsProxyHelper:" + JSON.stringify(dataShareHelper));
    resultSet = await dataShareHelper!.query(uri, da, columns);
    expect(resultSet != undefined).assertTrue();
    resultSet!.goToFirstRow()
    let long1 = resultSet!.getLong(resultSet!.getColumnIndex("age"));
    console.info(TAG + "long1:" + JSON.stringify(long1));
    if (0 == long1) {
      ReturnCode = 1;
    } else {
      ReturnCode = -1;
    }
