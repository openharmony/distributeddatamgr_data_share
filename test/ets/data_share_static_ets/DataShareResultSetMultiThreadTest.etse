async function goToFirstRowTest(context: common.UIAbilityContext, value: Array<int>): Promise<Array<int>> {
  const TAG = "[ttt-goToFirstRowTest] "
  value = new Array<int>();
  let dataShareHelper: dataShare.DataShareHelper | undefined = undefined
  let uri = ("datashareproxy://com.acts.ohos.data.datasharetest.static/test");
  let ReturnCode = 0;
  let columns = ["*"];
  let da = new dataSharePredicates.DataSharePredicates();
  let resultSet: DataShareResultSet | undefined;
  try {
    dataShareHelper = await dataShare.createDataShareHelper(context, uri, { isProxy: true });
    console.log(TAG + "dsProxyHelper:" + JSON.stringify(dataShareHelper));
    resultSet = await dataShareHelper!.query(uri, da, columns);
    expect(resultSet != undefined).assertTrue();
    console.info(TAG + "rowcount:" + resultSet!.rowCount);
    let ret = resultSet!.goToFirstRow();
    if (ret) {
      console.info(TAG + "goToFirstRow success");
      ReturnCode = 1;
    } else {
      ReturnCode = -1;
    }
    value.push(ReturnCode);
    console.info(TAG + 'value is ' + JSON.stringify(value));
  } catch (err: BusinessError) {
    console.error(TAG + 'error' + err.code + "  " + err.message);
    ReturnCode = err.code;
    value.push(ReturnCode);
    console.info(TAG + 'error value is ' + JSON.stringify(value));
  } finally {
    resultSet?.close()
  }
  console.info(TAG + "end");
  return value;
}
 
